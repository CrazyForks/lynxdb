# file: backend_server.log
# format: json
from main
| stats count() as events, avg(duration_ms) as avg_dur, max(duration_ms) as max_dur, count(where status >= 500) as errors by service
| extend error_rate = round((float("errors*100") / events), 1)
| extend health = if(errors > 0, "unhealthy", "healthy")
| sort -errors, service
